SERVER_PORT=3000
ENV=development
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30
SERVER_IDLE_TIMEOUT=120
SERVER_SHUTDOWN_TIMEOUT=30

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=live_platform
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=3600
DB_MAX_CONN_IDLE=1800

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=stream-events

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=recordings
MINIO_MATERIALS_BUCKET=materials
MINIO_DOWNLOADS_BUCKET=downloads

# JWT (CHANGE IN PRODUCTION)
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# RTMP
RTMP_SERVER_URL=rtmp://localhost:1935/live
RTMP_STREAM_KEY=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=30

# TLS (optional — set TLS_ENABLED=true for HTTPS)
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Claude AI (for doubt solving)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# Razorpay (for subscriptions)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App
APP_BASE_URL=http://localhost:3000
HLS_BASE_URL=http://localhost:8080/hls
RTMP_BASE_URL=rtmp://localhost:1935/live
DEFAULT_LOCALE=en
